#!/usr/bin/env python3
import os
import signal
import socket
import subprocess
import sys


service_dir = os.path.expanduser(
    sys.argv[1] if len(sys.argv) > 1 else "~/.files/Waylandservices"
)
wayland_display = os.environ.get("WAYLAND_DISPLAY")
xdg_runtime_dir = os.environ.get("XDG_RUNTIME_DIR")

if not wayland_display:
    print("spawn-wayland-services: WAYLAND_DISPLAY not set", file=sys.stderr)
    sys.exit(1)

if not xdg_runtime_dir and not os.path.isabs(wayland_display):
    print("spawn-wayland-services: XDG_RUNTIME_DIR not set", file=sys.stderr)
    sys.exit(1)

if not os.path.isdir(service_dir):
    print(
        f"spawn-wayland-services: service directory does not exist: {service_dir}",
        file=sys.stderr,
    )
    sys.exit(1)

socket_path = (
    wayland_display
    if os.path.isabs(wayland_display)
    else os.path.join(xdg_runtime_dir, wayland_display)
)
nitro_env = os.environ.copy()
nitro_env["NITRO_SOCK"] = os.path.join(
    xdg_runtime_dir, f"nitro-{os.path.basename(wayland_display)}.sock"
)

sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
sock.connect(socket_path)
proc = subprocess.Popen(["nitro", service_dir], start_new_session=True, env=nitro_env)

def cleanup():
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass


signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
signal.signal(signal.SIGINT, lambda *_: sys.exit(0))
signal.signal(signal.SIGHUP, lambda *_: sys.exit(0))

try:
    while sock.recv(4096):
        pass
finally:
    sock.close()
    cleanup()
