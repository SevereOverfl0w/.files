#!/bin/sh

export castles="$HOME/.local/libexec/castles"
export PLUGINS="$castles/plugins"
export PATH="$castles/bin:$PATH"
castle_config="$HOME/.config/castles"

# OSTYPE does not exist in posix sh
case "$(uname)" in
    Linux) export ostype="linux" ;;
    Darwin) export ostype="darwin" ;;
esac

case "$ostype" in
    linux) os="$(lsb_release -cs)"; export os ;;
    darwin) export os="darwin" ;;
esac

castle(){
    echo "CASTLE: $1"
    "$castles/$1"
}

if [ $# -gt 0 ] && [ -e "$castle_config" ]; then
    for castle in "$@"; do
        castle "$castle"
    done
else
    if [ $# -gt 0 ]; then
        mkdir -p "${castle_config%/*}"
        for castle in "$@"; do
            echo "$castle" >> "$castle_config"
        done
    fi
    while IFS= read -r LINE; do
      castle "$LINE"
    done < "$castle_config"
fi
