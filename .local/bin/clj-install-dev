#!/bin/sh

":"; script="$(command -v "$0")"
":"; data_dir="$(dirname "$script")/../share/clj-install-dev"

"exec" "clojure" "-Sdeps" '{:deps {borkdude/rewrite-edn {:mvn/version "0.4.6"}}}' "-M" "$script" "$data_dir" "$@"

(require '[borkdude.rewrite-edn :as r]
         '[clojure.java.io :as io]
         '[clojure.string :as string])

(def home (System/getProperty "user.home"))
(def config-dir (or (System/getenv "CLJ_CONFIG")
                    (some-> (System/getenv "XDG_CONFIG_HOME") (str "/clojure"))
                    (str home "/.clojure")))
(def deps-f (io/file config-dir "deps.edn"))
(def deps-edn (r/parse-string (if (.exists deps-f) (slurp deps-f) "{}")))
(def data-dir (first *command-line-args*))
(def dev-alias
  (-> (r/parse-string (slurp (io/file data-dir "user-dev.edn")))
      (r/update :main-opts (comp #(update % 1 string/replace #"^~" home) r/sexpr))))

(io/make-parents deps-f)
(spit deps-f (str (r/assoc-in deps-edn [:aliases :user/dev] dev-alias)))
