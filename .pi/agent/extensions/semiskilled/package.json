{
  "name": "semiskilled",
  "version": "0.1.0",
  "description": "Pi extension for inline /skill expansion with rpiv-args substitutions.",
  "type": "module",
  "exports": {
    ".": "./index.ts"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "skills",
    "inline",
    "rpiv-args"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@juicesharp/rpiv-args": "^1.20.0",
    "typebox": "^1.3.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
